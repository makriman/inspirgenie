---
import PageLayout from '../layouts/PageLayout.astro';
import CTA from '../components/global/CTA.astro';
import PageHero from '../components/global/PageHero.astro';

const siteUrl = 'https://inspir.uk';
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "inspir learning LTD",
  "description": "Managed ecommerce operations for UK businesses. One dedicated operator, £999/month.",
  "url": siteUrl,
  "email": "hello@inspir.uk",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "London SW9 0PP",
    "addressCountry": "GB"
  },
  "areaServed": "GB",
  "priceRange": "£999/month"
};
---
<PageLayout
  title="About inspir — Ecommerce Ops, London | inspir"
  description="inspir learning LTD. Managed ecommerce operations for UK businesses. One operator, £999/month. Based in London SW9."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(localBusinessSchema)} />
  <PageHero
    breadcrumbs={[{ label: 'About' }]}
    label="About inspir"
    title="Built for UK ecommerce businesses."
    description="Managed ecommerce operations for UK businesses. One dedicated operator, 40 hours a week."
  />

  <!-- Body copy -->
  <section class="py-16 bg-white">
    <div class="container max-w-3xl">
      <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
        <p>
          Running an ecommerce store in the UK means wearing every hat. Marketing, finance, operations, support — all you, all at once. That's unsustainable at any revenue level. Your store deserves dedicated operational support, not whatever's left of you at 10pm.
        </p>
        <p>
          We built inspir because the gap between "I can't afford to hire someone full-time" and "I can't keep doing this alone" is where most UK ecommerce businesses get stuck. One dedicated operator, 40 hours a week, at a fraction of the cost of a full-time hire.
        </p>
        <p>
          We're not a freelancer marketplace. We're not a chatbot. We're a managed operations partner — which means we vet, train, supervise, and stand behind the work our operators do.
        </p>
      </div>
    </div>
  </section>

  <!-- How we're different -->
  <section class="py-20 lg:py-24" style="background-color: #0C1F40;">
    <div class="container">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-widest text-electric-lime mb-3">What sets us apart</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white" style="font-family: var(--font-heading);">
          Not a platform. Not a marketplace.
        </h2>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        {[
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8"><path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM3.751 20.105a8.25 8.25 0 0116.498 0 .75.75 0 01-.437.695A18.683 18.683 0 0112 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 01-.437-.695z" clip-rule="evenodd" /></svg>',
            title: 'Dedicated, not shared',
            desc: 'Your operator works for you, not split across ten clients. One person, fully focused on your store and your processes.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8"><path fill-rule="evenodd" d="M7.502 6h7.128A3.375 3.375 0 0118 9.375v9.375a3 3 0 003-3V6.108c0-1.505-1.125-2.811-2.664-2.94a48.972 48.972 0 00-.673-.05A3 3 0 0015 1.5h-1.5a3 3 0 00-2.663 1.618c-.225.015-.45.032-.673.05C8.662 3.295 7.554 4.542 7.502 6zM13.5 3A1.5 1.5 0 0012 4.5h4.5A1.5 1.5 0 0015 3h-1.5z" clip-rule="evenodd" /><path fill-rule="evenodd" d="M3 9.375C3 8.339 3.84 7.5 4.875 7.5h9.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-9.75A1.875 1.875 0 013 20.625V9.375zM6 12a.75.75 0 01.75-.75h.008a.75.75 0 01.75.75v.008a.75.75 0 01-.75.75H6.75a.75.75 0 01-.75-.75V12zm2.25 0a.75.75 0 01.75-.75h3.75a.75.75 0 010 1.5H9a.75.75 0 01-.75-.75zM6 15a.75.75 0 01.75-.75h.008a.75.75 0 01.75.75v.008a.75.75 0 01-.75.75H6.75a.75.75 0 01-.75-.75V15zm2.25 0a.75.75 0 01.75-.75h3.75a.75.75 0 010 1.5H9a.75.75 0 01-.75-.75zM6 18a.75.75 0 01.75-.75h.008a.75.75 0 01.75.75v.008a.75.75 0 01-.75.75H6.75a.75.75 0 01-.75-.75V18zm2.25 0a.75.75 0 01.75-.75h3.75a.75.75 0 010 1.5H9a.75.75 0 01-.75-.75z" clip-rule="evenodd" /></svg>',
            title: 'Documented, not ad hoc',
            desc: 'Every action is logged. Weekly reports. Full audit trail. You always know what\'s being done, when, and why.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8"><path d="M16.5 7.5h-9v9h9v-9z" /><path fill-rule="evenodd" d="M8.25 2.25A.75.75 0 019 3v.75h2.25V3a.75.75 0 011.5 0v.75H15V3a.75.75 0 011.5 0v.75h.75a3 3 0 013 3v.75H21A.75.75 0 0121 9h-.75v2.25H21a.75.75 0 010 1.5h-.75V15H21a.75.75 0 010 1.5h-.75v.75a3 3 0 01-3 3h-.75V21a.75.75 0 01-1.5 0v-.75h-2.25V21a.75.75 0 01-1.5 0v-.75H9V21a.75.75 0 01-1.5 0v-.75h-.75a3 3 0 01-3-3v-.75H3A.75.75 0 013 15h.75v-2.25H3a.75.75 0 010-1.5h.75V9H3a.75.75 0 010-1.5h.75v-.75a3 3 0 013-3h.75V3a.75.75 0 01.75-.75zM6 6.75A.75.75 0 016.75 6h10.5a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75H6.75a.75.75 0 01-.75-.75V6.75z" clip-rule="evenodd" /></svg>',
            title: 'AI-trained, not traditional',
            desc: 'Our operators work with modern AI tools to move faster and catch more. Faster ticket drafts, smarter categorisation, better QA.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 00.374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08zm3.094 8.016a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" /></svg>',
            title: 'Managed, not freelance',
            desc: 'We vet, train, and supervise every operator. If something goes wrong, you contact us. We fix it. No chasing someone on Upwork.'
          }
        ].map(item => (
          <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-8 border border-white/20">
            <div class="text-white mb-4">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-bold text-white text-xl mb-3" style="font-family: var(--font-heading);">{item.title}</h3>
            <p class="text-blue-200 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company details -->
  <section class="py-20 lg:py-24 bg-white">
    <div class="container max-w-3xl mx-auto">
      <h2 class="text-3xl font-extrabold text-dark mb-10 text-center" style="font-family: var(--font-heading);">Company details</h2>

      <div class="bg-cream rounded-2xl p-8 border border-gray-200">
        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <h3 class="font-bold text-dark mb-4 uppercase text-xs tracking-widest text-gray-400">Registered company</h3>
            <p class="font-bold text-dark text-lg">inspir learning LTD</p>
            <p class="text-gray-600">Registered in England and Wales</p>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-4 uppercase text-xs tracking-widest text-gray-400">Address</h3>
            <p class="text-gray-600">London SW9 0PP<br />United Kingdom</p>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-4 uppercase text-xs tracking-widest text-gray-400">Contact</h3>
            <a href="mailto:hello@inspir.uk" class="text-purple font-semibold hover:text-deep-blue transition-colors">hello@inspir.uk</a>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-4 uppercase text-xs tracking-widest text-gray-400">Response time</h3>
            <p class="text-gray-600">Within 24 hours. Usually faster.</p>
          </div>
        </div>
      </div>

      <div class="mt-8 p-6 bg-cream rounded-xl border border-gray-200">
        <h3 class="font-bold text-dark mb-3">UK-focused from the start</h3>
        <p class="text-gray-600 text-sm leading-relaxed">
          GBP pricing, UK business hours coverage, GDPR compliance, and operators briefed on UK consumer expectations. We price in pounds and understand the UK ecommerce market — not an afterthought.
        </p>
      </div>
    </div>
  </section>

  <!-- The team -->
  <section class="py-20 lg:py-24 bg-cream">
    <div class="container max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">The team</p>
      <h2 class="text-3xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">Built by operators, not a marketplace.</h2>
      <div class="space-y-4 text-gray-600 leading-relaxed">
        <p>inspir was built by people who have worked inside UK ecommerce businesses — managing operations, dealing with support queues, handling returns, chasing suppliers. We know what the daily grind looks like because we've done it.</p>
        <p>We're not a freelancer marketplace or a staffing agency. We're the people responsible for your operations. Every operator we place is vetted, trained to our standard, and backed by an account team who knows your store. When something goes wrong — and in ecommerce, something always eventually does — you have a named person to call.</p>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 lg:py-24 bg-white">
    <div class="container max-w-3xl mx-auto">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">How we work</p>
        <h2 class="text-3xl font-extrabold text-dark" style="font-family: var(--font-heading);">Four things we don't compromise on.</h2>
      </div>

      <div class="grid grid-cols-2 gap-6">
        {[
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-purple"><path d="M12 15a3 3 0 100-6 3 3 0 000 6z" /><path fill-rule="evenodd" d="M1.323 11.447C2.811 6.976 7.028 3.75 12.001 3.75c4.97 0 9.185 3.223 10.675 7.69.12.362.12.752 0 1.113-1.487 4.471-5.705 7.697-10.677 7.697-4.97 0-9.186-3.223-10.675-7.69a1.762 1.762 0 010-1.113zM17.25 12a5.25 5.25 0 11-10.5 0 5.25 5.25 0 0110.5 0z" clip-rule="evenodd" /></svg>',
            value: 'Transparency',
            desc: 'You see everything. Reports, trails, costs. No black boxes.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-purple"><path fill-rule="evenodd" d="M12.516 2.17a.75.75 0 00-1.032 0 11.209 11.209 0 01-7.877 3.08.75.75 0 00-.722.515A12.74 12.74 0 002.25 9.75c0 5.942 4.064 10.933 9.563 12.348a.749.749 0 00.374 0c5.499-1.415 9.563-6.406 9.563-12.348 0-1.39-.223-2.73-.635-3.985a.75.75 0 00-.722-.516l-.143.001c-2.996 0-5.717-1.17-7.734-3.08zm3.094 8.016a.75.75 0 10-1.22-.872l-3.236 4.53L9.53 12.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.14-.094l3.75-5.25z" clip-rule="evenodd" /></svg>',
            value: 'Ownership',
            desc: 'Your operator treats your store as their own responsibility.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-purple"><path d="M18.75 12.75h1.5a.75.75 0 000-1.5h-1.5a.75.75 0 000 1.5zM12 6a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5A.75.75 0 0112 6zM12 18a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5A.75.75 0 0112 18zM3.75 6.75h1.5a.75.75 0 100-1.5h-1.5a.75.75 0 000 1.5zM5.25 18.75h-1.5a.75.75 0 010-1.5h1.5a.75.75 0 010 1.5zM3 12a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5A.75.75 0 013 12zM9 3.75a2.25 2.25 0 100 4.5 2.25 2.25 0 000-4.5zM12.75 12a2.25 2.25 0 114.5 0 2.25 2.25 0 01-4.5 0zM9 15.75a2.25 2.25 0 100 4.5 2.25 2.25 0 000-4.5z" /></svg>',
            value: 'Precision',
            desc: 'Right first time. Every listing, every ticket, every order.'
          },
          {
            icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-purple"><path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0112.548-3.364l1.903 1.903h-3.183a.75.75 0 100 1.5h4.992a.75.75 0 00.75-.75V4.356a.75.75 0 00-1.5 0v3.18l-1.9-1.9A9 9 0 003.306 9.67a.75.75 0 101.45.388zm15.408 3.352a.75.75 0 00-.919.53 7.5 7.5 0 01-12.548 3.364l-1.902-1.903h3.183a.75.75 0 000-1.5H3.984a.75.75 0 00-.75.75v4.992a.75.75 0 001.5 0v-3.18l1.9 1.9a9 9 0 0015.059-4.035.75.75 0 00-.53-.918z" clip-rule="evenodd" /></svg>',
            value: 'Adaptability',
            desc: 'Your processes change. Your operator adapts without drama.'
          }
        ].map(item => (
          <div class="bg-cream rounded-2xl p-6 border border-gray-200">
            <div class="mb-3">
              <Fragment set:html={item.icon} />
            </div>
            <h3 class="font-extrabold text-dark text-xl mb-2" style="font-family: var(--font-heading);">{item.value}</h3>
            <p class="text-gray-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
