---
import PageLayout from '../layouts/PageLayout.astro';
import CTA from '../components/global/CTA.astro';
import Breadcrumbs from '../components/global/Breadcrumbs.astro';
import Accordion from '../components/ui/Accordion.astro';
import { faqCategories } from '../data/faq';

const pricingFAQs = faqCategories.find(c => c.slug === 'pricing')?.items ?? [];

const siteUrl = 'https://inspir.uk';

const volumePricing = [
  { operators: '1', monthly: '£999/mo', annual: '£9,990/yr', saving: '£1,998' },
  { operators: '3', monthly: '£2,997/mo', annual: '£29,970/yr', saving: '£5,994' },
  { operators: '5', monthly: '£4,995/mo', annual: '£49,950/yr', saving: '£9,990' },
  { operators: '10', monthly: '£9,990/mo', annual: '£99,900/yr', saving: '£19,980' },
  { operators: '10+', monthly: 'Custom', annual: 'Custom', saving: 'Contact us' },
];

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Managed Ecommerce Operations",
  "offers": {
    "@type": "Offer",
    "price": "999",
    "priceCurrency": "GBP",
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "999",
      "priceCurrency": "GBP",
      "unitText": "MONTH"
    },
    "description": "One dedicated ecommerce operator, 40 hours per week, all platforms supported"
  }
};
---
<PageLayout
  title="Pricing — Dedicated Ecommerce Operator £999/mo | inspir"
  description="One dedicated ecommerce operator, 40 hours a week, £999/month. See what's included, volume pricing, and how it compares to hiring in-house."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pricingSchema)} />

  <Breadcrumbs items={[{ label: 'Pricing' }]} />

  <!-- Hero -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="container text-center max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-4">Pricing</p>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">
        One price. No surprises.
      </h1>
      <p class="text-xl text-gray-600">
        £999 a month. One dedicated operator. 40 hours a week. Cancel anytime.
      </p>
    </div>
  </section>

  <!-- Main Price Card -->
  <section class="pb-20 bg-cream">
    <div class="container">
      <div class="max-w-lg mx-auto bg-white rounded-2xl border-2 border-electric-lime shadow-xl shadow-purple/10 p-10">
        <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-2">Standard Plan</p>
        <div class="flex items-baseline gap-2 mb-1">
          <span class="text-6xl font-extrabold text-coral" style="font-family: var(--font-heading);">£999</span>
          <span class="text-gray-400 text-xl">/month</span>
        </div>
        <p class="text-gray-500 mb-8">per dedicated operator</p>

        <div class="mb-8 p-5 bg-cream rounded-xl">
          <div class="flex items-center justify-between mb-1">
            <span class="font-bold text-dark text-lg">£9,990/year</span>
            <span class="text-sm bg-electric-lime text-dark px-3 py-1 rounded-full font-bold">Save £1,998</span>
          </div>
          <p class="text-sm text-gray-500">Two months free. Billed upfront.</p>
        </div>

        <a href="/contact" class="block w-full text-center bg-electric-lime text-dark font-bold py-4 rounded-xl text-lg hover:opacity-90 transition-opacity mb-4">
          Get started today →
        </a>
        <p class="text-center text-xs text-gray-400">No lock-in · Cancel anytime · GBP billing</p>
      </div>
    </div>
  </section>

  <!-- What's included -->
  <section class="py-20 lg:py-28" style="background-color: #1e40af;">
    <div class="container">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-widest text-electric-lime mb-3">What's included</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white" style="font-family: var(--font-heading);">
          Everything in the price.
        </h2>
        <p class="text-blue-200 mt-4 max-w-xl mx-auto">No add-ons. No tiers. No hidden setup fees. This is what £999 gets you.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {[
          { icon: '👤', title: '1 dedicated operator', desc: 'One person assigned to your store — not a pool, not a rotation. The same operator every day.' },
          { icon: '⏱️', title: '40 hours per week', desc: 'A full working week on your store. Not 20 hours, not shared time. Forty hours.' },
          { icon: '🌍', title: 'Timezone matched', desc: 'Your operator works your hours, not someone else\'s timezone. Coverage when you need it.' },
          { icon: '🛒', title: 'All platforms', desc: 'Shopify, WooCommerce, Magento, BigCommerce, Wix, Squarespace — whatever you run.' },
          { icon: '🤖', title: 'AI-trained operator', desc: 'Uses modern AI tools to work faster and catch more. The human is always accountable.' },
          { icon: '📊', title: 'Weekly reports', desc: 'Volume, quality, escalations — every week. You always know what\'s been done.' },
          { icon: '📋', title: 'Full audit trail', desc: 'Every action logged. Who did what, when, and why. Total visibility.' },
          { icon: '📝', title: 'SOP documentation', desc: 'Your processes are written down. Continuity if your operator is unavailable.' },
          { icon: '💬', title: 'Free AI chatbot', desc: 'Deployed on your store, trained on your FAQs. Handles routine queries 24/7.' },
          { icon: '🏢', title: 'Named account contact', desc: 'A real person at inspir in London. Not a ticket system. Not a shared inbox.' },
        ].map(item => (
          <div class="bg-white/10 backdrop-blur-sm rounded-xl p-6 border border-white/20">
            <div class="text-3xl mb-3">{item.icon}</div>
            <h3 class="font-bold text-white mb-2" style="font-family: var(--font-heading);">{item.title}</h3>
            <p class="text-blue-200 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Volume pricing -->
  <section class="py-20 lg:py-28 bg-cream">
    <div class="container">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">Volume pricing</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark" style="font-family: var(--font-heading);">
          More operators, same rate.
        </h2>
        <p class="text-gray-600 mt-4 max-w-lg mx-auto">Each additional operator is £999/month. Annual pricing available at all tiers.</p>
      </div>

      <div class="max-w-3xl mx-auto overflow-x-auto rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 bg-gray-50">
              <th class="text-left p-5 font-bold text-dark">Operators</th>
              <th class="p-5 font-bold text-dark">Monthly</th>
              <th class="p-5 font-bold text-dark">Annual</th>
              <th class="p-5 font-bold text-dark">Annual saving</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {volumePricing.map((row, i) => (
              <tr class={i === 0 ? 'bg-electric-lime/10' : ''}>
                <td class="p-5">
                  <span class={`font-bold ${i === 0 ? 'text-dark' : 'text-gray-700'}`}>
                    {row.operators} operator{row.operators !== '1' && row.operators !== '10+' ? 's' : row.operators === '10+' ? '+' : ''}
                  </span>
                  {i === 0 && <span class="ml-2 text-xs bg-electric-lime text-dark px-2 py-0.5 rounded-full font-semibold">Most popular</span>}
                </td>
                <td class={`p-5 text-center font-semibold ${i === 0 ? 'text-coral' : 'text-gray-700'}`}>{row.monthly}</td>
                <td class="p-5 text-center text-gray-700">{row.annual}</td>
                <td class="p-5 text-center">
                  {row.saving === 'Contact us' ? (
                    <a href="/contact" class="text-purple font-semibold hover:underline text-xs">{row.saving}</a>
                  ) : (
                    <span class="text-green-700 font-semibold text-xs">{row.saving}</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Cost comparison deep dive -->
  <section class="py-20 lg:py-28 bg-white">
    <div class="container max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">The maths</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-dark" style="font-family: var(--font-heading);">
          The real cost of the alternatives.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- inspir -->
        <div class="bg-cream rounded-2xl p-8 border-2 border-electric-lime">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">✓</span>
            <h3 class="font-bold text-dark text-xl" style="font-family: var(--font-heading);">inspir</h3>
          </div>
          <div class="text-4xl font-extrabold text-coral mb-2" style="font-family: var(--font-heading);">£9,990</div>
          <p class="text-gray-500 text-sm mb-6">per year, annual plan</p>
          <ul class="space-y-2 text-sm">
            {['No employer NI', 'No pension contribution', 'No recruitment fees', 'No management overhead', 'Cancel anytime', 'Ecommerce specialist', 'Audit trail included', 'SOP documentation'].map(item => (
              <li class="flex items-center gap-2 text-gray-700">
                <svg class="w-4 h-4 text-purple flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- UK Junior Hire -->
        <div class="bg-cream rounded-2xl p-8 border border-gray-200">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">💼</span>
            <h3 class="font-bold text-dark text-xl" style="font-family: var(--font-heading);">UK junior hire</h3>
          </div>
          <div class="text-4xl font-extrabold text-gray-400 mb-2" style="font-family: var(--font-heading);">~£34,000</div>
          <p class="text-gray-500 text-sm mb-6">per year, true cost</p>
          <ul class="space-y-2 text-sm text-gray-600">
            <li>Salary: ~£28,000</li>
            <li>Employer NI: ~£3,000</li>
            <li>Pension: ~£1,000</li>
            <li>Recruitment: £2,000–5,000</li>
            <li>Notice period risk</li>
            <li>HR and management time</li>
            <li>Training investment</li>
          </ul>
          <p class="text-xs text-gray-400 mt-4">3.4x the cost of inspir annually.</p>
        </div>

        <!-- Agency -->
        <div class="bg-cream rounded-2xl p-8 border border-gray-200">
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">🏢</span>
            <h3 class="font-bold text-dark text-xl" style="font-family: var(--font-heading);">Agency</h3>
          </div>
          <div class="text-4xl font-extrabold text-gray-400 mb-2" style="font-family: var(--font-heading);">£24,000–60,000</div>
          <p class="text-gray-500 text-sm mb-6">per year</p>
          <ul class="space-y-2 text-sm text-gray-600">
            <li>£2,000–5,000/month typical</li>
            <li>Account manager buffer</li>
            <li>Shared team, not dedicated</li>
            <li>One of many clients</li>
            <li>Slow response times</li>
            <li>Impersonal, high turnover</li>
            <li>Limited ecommerce ops focus</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Payment details -->
  <section class="py-16 bg-cream">
    <div class="container max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-2xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">Payment details</h2>
        <div class="grid md:grid-cols-2 gap-6 text-sm text-gray-600">
          <div>
            <h3 class="font-bold text-dark mb-2">Billing</h3>
            <p>Monthly in advance. Bank transfer or invoice is standard. Stripe or card payment available on request.</p>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-2">Currency</h3>
            <p>All prices in GBP. Proper B2B invoices issued from inspir learning LTD for every payment.</p>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-2">Contract</h3>
            <p>Monthly rolling. No lock-in. Cancel with written notice before your next billing date.</p>
          </div>
          <div>
            <h3 class="font-bold text-dark mb-2">Annual plan</h3>
            <p>Paid upfront, saves £1,998 on the standard plan. Annual clients get priority operator matching.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing FAQ -->
  <section class="py-20 lg:py-24 bg-cream">
    <div class="container max-w-3xl mx-auto">
      <h2 class="text-2xl font-extrabold text-dark mb-10 text-center" style="font-family: var(--font-heading);">Pricing questions</h2>
      <Accordion items={pricingFAQs} />
    </div>
  </section>

  <CTA heading="Ready to get started?" subheading="One operator. 40 hours a week. Live in two weeks." />
</PageLayout>
