---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/global/PageHero.astro';
import CTA from '../../components/global/CTA.astro';
import { platforms } from '../../data/platforms';
const platform = platforms.find(p => p.slug === 'shopify')!;
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Shopify Operations Support",
  "description": "Dedicated Shopify operator for UK businesses. Orders, support, catalogue, returns — fully managed.",
  "provider": { "@type": "Organization", "name": "inspir learning LTD" },
  "serviceType": "Shopify Operations Management",
  "areaServed": "GB"
};
---
<PageLayout
  title="Shopify Operations Support UK | inspir"
  description="Hire a dedicated Shopify operator for £999/month. Orders, support, catalogue, returns — fully managed. Works with Shopify and Shopify Plus."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <PageHero
    breadcrumbs={[{ label: 'Platforms', href: '/platforms' }, { label: 'Shopify' }]}
    label="Shopify"
    title="Shopify operations support for UK businesses."
    description="A dedicated Shopify operator who knows the platform, your apps, and your admin. From orders to catalogue to customer support — one person, 40 hours a week, £999/month."
  />
  <section class="py-16 lg:py-20 bg-cream">
    <div class="container max-w-3xl mx-auto">
      <div class="mb-16 bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-2xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">The operational challenge of running Shopify</h2>
        <div class="space-y-4 text-gray-600">
          <p>Shopify makes it easy to sell. The operations side is a different story. Customer emails pile up. Orders need processing. Products need uploading. Every day, dozens of tasks that take you away from growing the business.</p>
          <p>Shopify Plus adds complexity — Scripts, Flow, custom checkout logic, B2B features. Most UK Shopify stores run 10–20 apps, each with its own admin and failure modes. Your dedicated inspir operator knows Shopify properly. Not a generalist — someone who works in Shopify admin every day.</p>
        </div>
      </div>
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">What your Shopify operator handles</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {platform.features.map(feature => (
            <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-200 hover:border-purple/40 hover:shadow-sm transition-all">
              <svg class="w-5 h-5 text-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
              <span class="text-sm text-gray-700">{feature}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="mb-16 bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-2xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">Shopify ecosystem expertise</h2>
        <p class="text-gray-600 mb-5">Your operator is trained on the apps that power Shopify stores — not just the platform admin.</p>
        <div class="flex flex-wrap gap-2">
          {platform.apps.map(app => (
            <span class="inline-flex items-center bg-white text-dark text-xs font-semibold px-3 py-1.5 rounded-full border border-gray-200 shadow-sm hover:border-purple/40 transition-colors">{app}</span>
          ))}
        </div>
        <p class="text-gray-500 text-sm mt-4">Using something not on this list? We train on it during onboarding.</p>
      </div>
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">Why outsource Shopify operations?</h2>
        <div class="space-y-4">
          {[
            { title: 'Cost', desc: 'A dedicated Shopify operator from inspir costs £999/month — versus £28,000+ salary plus NI, pension, and management overhead for an in-house hire.' },
            { title: 'Consistency', desc: 'SOPs are documented. Every action is logged. The trail is clean whether you\'re checking in on Monday or an auditor is reviewing six months of work.' },
            { title: 'Focus', desc: 'Your operator handles operations. You focus on marketing, growth, and product. That\'s the right division of labour.' },
            { title: 'Flexibility', desc: 'Monthly rolling contract. Cancel anytime. Scale up with additional operators if your volume grows.' },
          ].map(item => (
            <div class="p-6 bg-cream rounded-xl border border-gray-200">
              <h3 class="font-bold text-dark mb-2" style="font-family: var(--font-heading);">{item.title}</h3>
              <p class="text-gray-600 text-sm">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
      <div class="mb-16 bg-electric-lime/20 rounded-2xl p-8 border border-electric-lime/40">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <p class="font-bold text-dark text-xl mb-1" style="font-family: var(--font-heading);">Dedicated Shopify operator</p>
            <p class="text-gray-600 text-sm">40 hours per week · all Shopify tasks · cancel anytime</p>
          </div>
          <div class="text-right">
            <p class="text-3xl font-extrabold text-coral" style="font-family: var(--font-heading);">£999/mo</p>
            <a href="/pricing" class="text-sm text-purple font-semibold hover:underline">See full pricing →</a>
          </div>
        </div>
      </div>
      <div class="mb-12 p-6 bg-white rounded-2xl border border-gray-200">
        <h3 class="font-bold text-dark mb-3" style="font-family: var(--font-heading);">We also support</h3>
        <div class="flex flex-wrap gap-4">
          <a href="/platforms/woocommerce" class="text-sm text-purple font-semibold hover:underline">WooCommerce</a>
          <span class="text-gray-300">·</span>
          <a href="/platforms/magento" class="text-sm text-purple font-semibold hover:underline">Magento</a>
          <span class="text-gray-300">·</span>
          <a href="/platforms/bigcommerce" class="text-sm text-purple font-semibold hover:underline">BigCommerce</a>
          <span class="text-gray-300">·</span>
          <a href="/platforms" class="text-sm text-purple font-semibold hover:underline">All platforms</a>
        </div>
      </div>
      <div class="flex gap-4 flex-wrap">
        <a href="/contact" class="bg-electric-lime text-dark font-bold px-8 py-4 rounded-xl hover:opacity-90 transition-opacity">Get started →</a>
        <a href="/services" class="border border-gray-300 text-dark font-semibold px-8 py-4 rounded-xl hover:border-purple transition-colors">See all services →</a>
      </div>
    </div>
  </section>
  <CTA />
</PageLayout>
