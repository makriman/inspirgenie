---
import PageLayout from '../../layouts/PageLayout.astro';
import PageHero from '../../components/global/PageHero.astro';
import CTA from '../../components/global/CTA.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Ecommerce Returns and Refunds Management",
  "description": "RMA creation, refund processing, restocking coordination, and return analytics. Every return handled per your policy.",
  "provider": { "@type": "Organization", "name": "inspir learning LTD" },
  "serviceType": "Ecommerce Returns Management",
  "areaServed": "GB"
};
---
<PageLayout
  title="Ecommerce Returns and Refunds UK | inspir"
  description="RMA creation, refund processing, restocking coordination for UK stores. Every return handled per your policy."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <PageHero
    breadcrumbs={[{ label: 'Services', href: '/services' }, { label: 'Returns & Refunds' }]}
    label="Returns & Refunds"
    title="Returns, refunds, and RMA management."
    description="RMA creation, refund processing, restocking coordination, and return analytics. Every return handled per your policy."
  />

  <section class="py-16 lg:py-20 bg-cream">
    <div class="container max-w-3xl mx-auto">

      <!-- What's covered -->
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">What your operator handles</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            'RMA creation and tracking',
            'Refund processing per your policy',
            'Restocking coordination',
            'Return reason logging and analytics',
            'Exchange management',
            'Returns portal management (Loop, Returnly)',
            'Fraud flag review and escalation',
            'Policy enforcement',
            'Carrier claim filing',
            'Return status communication',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-200 hover:border-purple/40 hover:shadow-sm transition-all">
              <svg class="w-5 h-5 text-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- How it works -->
      <div class="mb-16 bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-2xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">How your operator works</h2>
        <div class="space-y-4 text-gray-600">
          <p>Your operator follows your returns policy to the letter. RMAs are created correctly, returns are logged with reason codes, and restocking is coordinated with your warehouse or 3PL.</p>
          <p>Fraud flags are reviewed and escalated appropriately — your operator knows the difference between a legitimate return and a suspicious pattern, and documents both clearly.</p>
          <p>Weekly reports include return rate, top return reasons, and refund totals — giving you the data to spot product issues, sizing problems, or fulfilment errors before they compound.</p>
        </div>
      </div>

      <!-- Common scenarios -->
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">Common scenarios</h2>
        <div class="space-y-4">
          {[
            { title: 'High return rate', desc: 'Your return rate is climbing and you need to understand why. Your operator logs every return reason systematically, giving you clean data to identify which SKUs or suppliers are driving the volume.' },
            { title: 'No returns portal', desc: "You're handling returns manually through email. Your operator sets up a self-serve returns portal (Loop, Returnly, or similar), reducing the support overhead and improving the customer experience." },
            { title: 'Policy disputes', desc: 'Customers disputing return decisions or pushing back on policy. Your operator handles these professionally, documents the reasoning, and escalates the edge cases that need your input.' },
          ].map(s => (
            <div class="p-6 bg-cream rounded-xl border border-gray-200">
              <h3 class="font-bold text-dark mb-2" style="font-family: var(--font-heading);">{s.title}</h3>
              <p class="text-gray-600 text-sm">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Platforms -->
      <div class="mb-16 p-6 bg-white rounded-2xl border border-gray-200">
        <h2 class="text-xl font-extrabold text-dark mb-3" style="font-family: var(--font-heading);">Works on every platform</h2>
        <p class="text-gray-600 text-sm">Full returns management across Shopify, WooCommerce, Magento, BigCommerce, and all major ecommerce platforms. Compatible with Loop Returns, Returnly, and custom returns workflows.</p>
      </div>

      <!-- Related services -->
      <div class="mb-16">
        <h2 class="text-xl font-extrabold text-dark mb-4" style="font-family: var(--font-heading);">Related services</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/services/customer-support" class="p-4 bg-white rounded-xl border border-gray-200 hover:border-purple transition-colors text-sm font-semibold text-purple">Customer Support →</a>
          <a href="/services/order-management" class="p-4 bg-white rounded-xl border border-gray-200 hover:border-purple transition-colors text-sm font-semibold text-purple">Order Management →</a>
        </div>
      </div>

      <div class="flex gap-4">
        <a href="/contact" class="bg-electric-lime text-dark font-bold px-8 py-4 rounded-xl hover:opacity-90 transition-opacity">Get started →</a>
        <a href="/pricing" class="border border-gray-300 text-dark font-semibold px-8 py-4 rounded-xl hover:border-purple transition-colors">See pricing →</a>
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
