---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';
import CTA from '../../components/global/CTA.astro';
import { services, additionalServices } from '../../data/services';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Managed Ecommerce Operations",
  "provider": {
    "@type": "Organization",
    "name": "inspir learning LTD"
  },
  "serviceType": "Ecommerce Operations Management",
  "areaServed": "GB"
};
---
<PageLayout
  title="Managed Ecommerce Operations UK | inspir"
  description="Customer support, order management, catalogue ops, returns, inventory — all handled by your dedicated UK ecommerce operator."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <Breadcrumbs items={[{ label: 'Services' }]} />

  <section class="py-20 lg:py-28 bg-cream">
    <div class="container">
      <div class="text-center mb-16 max-w-2xl mx-auto">
        <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-4">Services</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">
          Everything your store needs. One operator.
        </h1>
        <p class="text-xl text-gray-600">
          Your dedicated operator handles every aspect of ecommerce operations. One person, one flat rate, all tasks.
        </p>
      </div>

      <!-- Main services grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
        {services.map(service => (
          <a href={`/services/${service.slug}`} class="group bg-white rounded-2xl p-8 border border-gray-200 hover:shadow-lg hover:border-purple/30 transition-all duration-200">
            <div class="text-4xl mb-5">{service.icon}</div>
            <h2 class="text-xl font-extrabold text-dark mb-3 group-hover:text-purple transition-colors" style="font-family: var(--font-heading);">{service.title}</h2>
            <p class="text-gray-600 mb-5 text-sm leading-relaxed">{service.description}</p>
            <ul class="space-y-1.5 mb-6">
              {service.bullets.slice(0, 3).map(b => (
                <li class="text-sm text-gray-500 flex items-start gap-2">
                  <span class="text-purple mt-1 flex-shrink-0">·</span>{b}
                </li>
              ))}
            </ul>
            <span class="text-sm font-semibold text-purple group-hover:text-deep-blue transition-colors">
              Learn more →
            </span>
          </a>
        ))}
      </div>

      <!-- Additional services -->
      <div class="bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">Also included</h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {additionalServices.map(s => (
            <div class="flex items-start gap-4">
              <div class="text-2xl">{s.icon}</div>
              <div>
                <h3 class="font-bold text-dark mb-1 text-sm">{s.title}</h3>
                <p class="text-xs text-gray-600">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="text-center mt-16">
        <p class="text-gray-600 mb-6">All services are included in the flat £999/month rate.</p>
        <a href="/pricing" class="inline-block bg-electric-lime text-dark font-bold px-8 py-4 rounded-xl text-lg hover:opacity-90 transition-opacity">
          See pricing →
        </a>
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
