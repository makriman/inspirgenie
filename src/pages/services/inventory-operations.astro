---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/global/Breadcrumbs.astro';
import CTA from '../../components/global/CTA.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Ecommerce Inventory Operations",
  "description": "Stock level monitoring, inventory audits, supplier coordination. Never oversell. Never run out.",
  "provider": { "@type": "Organization", "name": "inspir learning LTD" },
  "serviceType": "Ecommerce Inventory Management",
  "areaServed": "GB"
};
---
<PageLayout
  title="Ecommerce Inventory Operations Management | inspir"
  description="Stock level monitoring, inventory audits, supplier coordination — never oversell, never run out. Managed by your dedicated operator."
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(serviceSchema)} />
  <Breadcrumbs items={[{ label: 'Services', href: '/services' }, { label: 'Inventory Operations' }]} />

  <section class="py-20 lg:py-28 bg-cream">
    <div class="container max-w-3xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-4">Inventory Operations</p>
      <h1 class="text-4xl lg:text-5xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">
        Inventory monitoring and supplier coordination.
      </h1>
      <p class="text-xl text-gray-600 mb-12">
        Stock level monitoring, inventory audits, supplier coordination. Never oversell. Never run out.
      </p>

      <!-- What's covered -->
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">What your operator handles</h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {[
            'Stock level monitoring and alerts',
            'Low stock threshold management',
            'Inventory audits and reconciliation',
            'Supplier restocking coordination',
            'Purchase order tracking',
            'Multi-location inventory management',
            'Inventory discrepancy investigation',
            'Oversell prevention',
            'Stock reservation management',
            'Demand forecasting support',
          ].map(item => (
            <div class="flex items-start gap-3 p-4 bg-white rounded-xl border border-gray-200">
              <svg class="w-5 h-5 text-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- How it works -->
      <div class="mb-16 bg-white rounded-2xl p-8 border border-gray-200">
        <h2 class="text-2xl font-extrabold text-dark mb-6" style="font-family: var(--font-heading);">How your operator works</h2>
        <div class="space-y-4 text-gray-600">
          <p>Your operator monitors stock levels against your thresholds daily. When a SKU hits its reorder point, they raise a restocking request to your supplier and track the purchase order through to goods receipt.</p>
          <p>Inventory discrepancies are investigated and documented — whether that's a fulfilment error, a system sync issue, or a warehouse count problem. Your operator tracks it down and gets the count corrected.</p>
          <p>Weekly reports include stock health across all locations, upcoming low-stock SKUs, and any supplier delays worth flagging. You stay informed without having to log in and check.</p>
        </div>
      </div>

      <!-- Common scenarios -->
      <div class="mb-16">
        <h2 class="text-2xl font-extrabold text-dark mb-8" style="font-family: var(--font-heading);">Common scenarios</h2>
        <div class="space-y-4">
          {[
            { title: 'Running out of stock on key SKUs', desc: 'Your bestsellers keep going out of stock before you notice. Your operator monitors thresholds, raises restock requests proactively, and tracks supplier lead times — so you stop losing sales to avoidable stockouts.' },
            { title: 'Multi-warehouse complexity', desc: 'You have stock across multiple locations and counts are regularly out of sync. Your operator reconciles inventory across all locations, investigates discrepancies, and keeps your platform counts accurate.' },
            { title: 'Supplier coordination delays', desc: 'Purchase orders get raised and then lost in email threads. Your operator tracks every PO from creation to delivery, chasing suppliers on your behalf and flagging delays before they become stockouts.' },
          ].map(s => (
            <div class="p-6 bg-cream rounded-xl border border-gray-200">
              <h3 class="font-bold text-dark mb-2" style="font-family: var(--font-heading);">{s.title}</h3>
              <p class="text-gray-600 text-sm">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Platforms -->
      <div class="mb-16 p-6 bg-white rounded-2xl border border-gray-200">
        <h2 class="text-xl font-extrabold text-dark mb-3" style="font-family: var(--font-heading);">Works on every platform</h2>
        <p class="text-gray-600 text-sm">Full inventory operations support across Shopify, WooCommerce, Magento, BigCommerce, and all major ecommerce platforms. Compatible with Cin7, Linnworks, Brightpearl, and other inventory management systems.</p>
      </div>

      <!-- Related services -->
      <div class="mb-16">
        <h2 class="text-xl font-extrabold text-dark mb-4" style="font-family: var(--font-heading);">Related services</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <a href="/services/catalogue-management" class="p-4 bg-white rounded-xl border border-gray-200 hover:border-purple transition-colors text-sm font-semibold text-purple">Catalogue Management →</a>
          <a href="/services/order-management" class="p-4 bg-white rounded-xl border border-gray-200 hover:border-purple transition-colors text-sm font-semibold text-purple">Order Management →</a>
        </div>
      </div>

      <div class="flex gap-4">
        <a href="/contact" class="bg-electric-lime text-dark font-bold px-8 py-4 rounded-xl hover:opacity-90 transition-opacity">Get started →</a>
        <a href="/pricing" class="border border-gray-300 text-dark font-semibold px-8 py-4 rounded-xl hover:border-purple transition-colors">See pricing →</a>
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
