---
import { services, additionalServices } from '../../data/services';

const allServiceCards = [
  ...services.map(s => ({
    icon: s.icon,
    title: s.shortTitle,
    bullets: s.bullets.slice(0, 3),
    href: `/services/${s.slug}`
  })),
  ...additionalServices.map(s => ({
    icon: s.icon,
    title: s.title,
    bullets: [s.description],
    href: '/services'
  }))
];
---
<section class="py-20 lg:py-28 bg-cream">
  <div class="container">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">What your operator handles</p>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-dark" style="font-family: var(--font-heading);">
        Everything your store needs. One operator.
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {allServiceCards.map(card => (
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:shadow-lg transition-all duration-200 hover:-translate-y-0.5 flex flex-col">
          <div class="text-3xl mb-4">{card.icon}</div>
          <h3 class="text-lg font-bold text-dark mb-3" style="font-family: var(--font-heading);">{card.title}</h3>
          <ul class="space-y-1.5 flex-1">
            {card.bullets.map(bullet => (
              <li class="text-sm text-gray-600 flex items-start gap-2">
                <span class="text-purple mt-1 flex-shrink-0">·</span>
                {bullet}
              </li>
            ))}
          </ul>
          <a href={card.href} class="mt-4 text-sm font-semibold text-purple hover:text-deep-blue transition-colors">
            Learn more →
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
