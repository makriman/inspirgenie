---
import { services, additionalServices } from '../../data/services';

const allServiceCards = [
  ...services.map(s => ({
    icon: s.icon,
    title: s.shortTitle,
    bullets: s.bullets.slice(0, 3),
    href: `/services/${s.slug}`
  })),
  ...additionalServices.map(s => ({
    icon: s.icon,
    title: s.title,
    bullets: [s.description],
    href: '/services'
  }))
];

