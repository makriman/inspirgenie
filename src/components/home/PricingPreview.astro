---
---
<section class="py-20 lg:py-28 bg-cream">
  <div class="container">
    <div class="text-center mb-16">
      <p class="text-sm font-semibold uppercase tracking-widest text-purple mb-3">Pricing</p>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-dark" style="font-family: var(--font-heading);">
        Simple pricing. No surprises.
      </h2>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-start max-w-5xl mx-auto">
      <!-- Price card -->
      <div class="bg-white rounded-2xl border-2 border-electric-lime shadow-xl shadow-purple/10 p-8">
        <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-2">Standard Plan</p>
        <div class="flex items-baseline gap-2 mb-1">
          <span class="text-5xl font-extrabold text-coral" style="font-family: var(--font-heading);">£999</span>
          <span class="text-gray-400">/month</span>
        </div>
        <p class="text-sm text-gray-500 mb-6">per dedicated operator</p>

        <div class="mb-6 p-4 bg-cream rounded-xl">
          <div class="flex items-center justify-between">
            <span class="font-bold text-dark">£9,990/year</span>
            <span class="text-xs bg-electric-lime text-dark px-2 py-1 rounded-full font-semibold">Save £1,998</span>
          </div>
          <p class="text-xs text-gray-500 mt-1">Two months free. Paid upfront.</p>
        </div>

        <ul class="space-y-2.5 mb-8">
          {[
            '1 dedicated operator',
            '40 hours per week',
            'Matched to your timezone',
            'All platforms supported',
            'AI-trained, modern tooling',
            'Weekly reports & audit trail',
            'SOP documentation',
            'Free AI chatbot for your store',
            'Named account contact',
            'Cancel anytime'
          ].map(item => (
            <li class="flex items-center gap-3 text-sm">
              <svg class="w-4 h-4 text-purple flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
              </svg>
              <span class="text-gray-700">{item}</span>
            </li>
          ))}
        </ul>

        <a href="/contact" class="block w-full text-center bg-electric-lime text-dark font-bold py-4 rounded-xl text-lg hover:opacity-90 transition-opacity">
          Get started →
        </a>
        <a href="/pricing" class="block text-center text-sm text-gray-400 hover:text-purple transition-colors mt-4">
          See full pricing details →
        </a>
      </div>

      <!-- Comparison table -->
      <div>
        <h3 class="text-lg font-bold text-dark mb-6" style="font-family: var(--font-heading);">
          Less than a third of the cost of hiring in-house.
        </h3>

        <div class="overflow-x-auto rounded-xl border border-gray-200">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left p-4 font-semibold text-gray-500"></th>
                <th class="p-4 font-bold text-dark bg-electric-lime/20 border-x border-electric-lime/30">inspir</th>
                <th class="p-4 font-semibold text-gray-500">UK hire</th>
                <th class="p-4 font-semibold text-gray-500">Freelancer</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr>
                <td class="p-4 text-gray-600">Monthly cost</td>
                <td class="p-4 text-center font-bold text-coral bg-electric-lime/10 border-x border-electric-lime/20">£999</td>
                <td class="p-4 text-center text-gray-600">~£2,800</td>
                <td class="p-4 text-center text-gray-600">£1,200–2,000</td>
              </tr>
              <tr>
                <td class="p-4 text-gray-600">Hours/week</td>
                <td class="p-4 text-center font-semibold bg-electric-lime/10 border-x border-electric-lime/20">40</td>
                <td class="p-4 text-center text-gray-600">37.5</td>
                <td class="p-4 text-center text-gray-600">Variable</td>
              </tr>
              <tr>
                <td class="p-4 text-gray-600">Ecommerce specialist</td>
                <td class="p-4 text-center text-purple font-bold bg-electric-lime/10 border-x border-electric-lime/20">✓</td>
                <td class="p-4 text-center text-gray-400">Maybe</td>
                <td class="p-4 text-center text-gray-400">Maybe</td>
              </tr>
              <tr>
                <td class="p-4 text-gray-600">Audit trail & reports</td>
                <td class="p-4 text-center text-purple font-bold bg-electric-lime/10 border-x border-electric-lime/20">✓</td>
                <td class="p-4 text-center text-gray-400">✗</td>
                <td class="p-4 text-center text-gray-400">✗</td>
              </tr>
              <tr>
                <td class="p-4 text-gray-600">Cancel anytime</td>
                <td class="p-4 text-center text-purple font-bold bg-electric-lime/10 border-x border-electric-lime/20">✓</td>
                <td class="p-4 text-center text-gray-400">Notice period</td>
                <td class="p-4 text-center text-gray-400">✓</td>
              </tr>
              <tr>
                <td class="p-4 text-gray-600">NI & overhead</td>
                <td class="p-4 text-center text-purple font-bold bg-electric-lime/10 border-x border-electric-lime/20">None</td>
                <td class="p-4 text-center text-gray-400">~£5k/yr</td>
                <td class="p-4 text-center text-gray-400">None</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="text-xs text-gray-400 mt-4">
          UK junior hire estimate: £28k salary + £3k employer NI + benefits = ~£34k/yr. inspir annual plan: £9,990/yr.
        </p>
      </div>
    </div>
  </div>
</section>
