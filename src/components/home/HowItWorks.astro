---
const steps = [
  {
    number: "01",
    title: "Scoping call",
    description: "We learn your operations, tools, volume, and timezone. You leave knowing exactly what your operator will handle."
  },
  {
    number: "02",
    title: "Contract & SLA",
    description: "Service levels, escalation rules, responsibilities. Straightforward contract. No long-term lock-in."
  },
  {
    number: "03",
    title: "First payment",
    description: "Monthly in advance. Onboarding starts immediately. Your operator is assigned within days."
  },
  {
    number: "04",
    title: "Two-week onboarding",
    description: "Your operator learns your SOPs, tools, and workflows. No SOPs? We build them. No helpdesk? We set one up."
  },
  {
    number: "05",
    title: "Go live",
    description: "Your operator starts executing. Full audit trail from day one. Weekly reports on volume, quality, and escalations."
  }
];
---
<section class="py-20 lg:py-28" style="background: linear-gradient(135deg, #1a3a9c 0%, #1e40af 60%, #1a3a9c 100%);">
  <div class="container">
    <div class="text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.14em] mb-3" style="color: #B6F03C;">How it works</p>
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Signed today. Live in two weeks.
      </h2>
    </div>

    <!-- Desktop: horizontal timeline -->
    <div class="hidden lg:grid grid-cols-5 gap-6 relative">
      <!-- Connecting line -->
      <div class="absolute top-8 left-[10%] right-[10%] h-px bg-white/15 z-0"></div>

      {steps.map(step => (
        <div class="relative z-10 text-center">
          <div class="w-16 h-16 rounded-full bg-white text-purple font-extrabold text-base flex items-center justify-center mx-auto mb-5 shadow-lg" style="font-family: var(--font-heading); box-shadow: 0 8px 24px rgba(0,0,0,0.25);">
            {step.number}
          </div>
          <h3 class="font-bold text-white text-sm mb-2" style="font-family: var(--font-heading);">{step.title}</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(186,210,255,0.75);">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Mobile: vertical timeline -->
    <div class="lg:hidden space-y-0 relative">
      <div class="absolute left-7 top-8 bottom-8 w-px bg-white/15"></div>
      {steps.map(step => (
        <div class="relative pl-20 pb-10 last:pb-0">
          <div class="absolute left-0 w-14 h-14 rounded-full bg-white text-purple font-extrabold text-sm flex items-center justify-center" style="font-family: var(--font-heading); box-shadow: 0 4px 16px rgba(0,0,0,0.25);">
            {step.number}
          </div>
          <h3 class="font-bold text-white text-sm mb-2 pt-3" style="font-family: var(--font-heading);">{step.title}</h3>
          <p class="text-sm leading-relaxed" style="color: rgba(186,210,255,0.75);">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-14">
      <a href="/how-it-works" class="inline-flex items-center gap-2 text-sm font-medium transition-colors" style="color: rgba(255,255,255,0.6);" onmouseover="this.style.color='rgba(255,255,255,1)'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
        See the full process in detail
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
