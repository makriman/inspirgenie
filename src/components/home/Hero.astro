---
---
<section class="relative min-h-screen flex items-center noise-overlay overflow-hidden" style="background-color: #1e40af;">
  <div class="container relative z-10 py-32 lg:py-40">
    <div class="max-w-3xl">
      <!-- Badges row -->
      <div class="flex flex-wrap gap-2 mb-8 animate-fade-up">
        {['All platforms', 'AI-trained', 'Live in 2 weeks', 'Cancel anytime'].map(badge => (
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide" style="background:rgba(255,255,255,0.13); color:rgba(255,255,255,0.86); border:1px solid rgba(255,255,255,0.22);">
            {badge}
          </span>
        ))}
      </div>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white leading-tight mb-6 animate-fade-up animate-fade-up-delay-1" style="font-family: var(--font-heading);">
        Hire a dedicated ecommerce operator. <span class="text-electric-lime">£999/month.</span>
      </h1>

      <!-- Subheading -->
      <p class="text-lg lg:text-xl mb-10 max-w-2xl leading-relaxed animate-fade-up animate-fade-up-delay-2" style="color:rgba(255,255,255,0.90);">
        One person. 40 hours a week. Your store, your processes, your timezone. Customer support, orders, catalogue, returns — every platform, fully managed.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-up animate-fade-up-delay-3">
        <a href="/contact" class="inline-flex items-center justify-center bg-electric-lime text-dark font-bold px-8 py-4 rounded-xl text-lg hover:opacity-90 transition-opacity">
          Get started →
        </a>
        <a href="/how-it-works" class="inline-flex items-center justify-center border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-xl text-lg hover:border-white hover:bg-white/10 transition-all">
          See how it works
        </a>
      </div>

    </div>
  </div>

  <!-- Decorative element -->
  <div class="absolute right-0 top-1/2 -translate-y-1/2 w-64 h-64 lg:w-96 lg:h-96 rounded-full opacity-10" style="background: radial-gradient(circle, #7c3aed, transparent); right: -5rem;"></div>
</section>
