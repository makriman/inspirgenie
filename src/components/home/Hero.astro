---
---
<section class="relative min-h-screen flex items-center overflow-hidden" style="background: linear-gradient(135deg, #1a3a9c 0%, #1e40af 50%, #2d3aad 100%);">

  <!-- Background geometric accent -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-[600px] h-[600px] opacity-[0.07]" style="background: radial-gradient(circle at 70% 30%, #7c3aed 0%, transparent 70%); transform: translate(15%, -15%);"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] opacity-[0.05]" style="background: radial-gradient(circle, #B6F03C, transparent 70%); transform: translate(-20%, 20%);"></div>
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 48px 48px;"></div>
  </div>

  <div class="container relative z-10 py-32 lg:py-44">
    <div class="max-w-3xl">

      <!-- Badge row -->
      <div class="flex flex-wrap gap-2 mb-8 animate-fade-up">
        {['All platforms', 'AI-trained', 'Live in 2 weeks', 'Cancel anytime'].map(badge => (
          <span class="text-xs font-semibold px-3 py-1.5 rounded-full uppercase tracking-wide" style="background:rgba(255,255,255,0.1); color:rgba(255,255,255,0.82); border:1px solid rgba(255,255,255,0.18);">
            {badge}
          </span>
        ))}
      </div>

      <!-- H1 -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-[4.25rem] font-extrabold text-white leading-[1.08] mb-6 animate-fade-up animate-fade-up-delay-1" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
        Hire a dedicated ecommerce operator.<br />
        <span class="text-[#B6F03C]">£999/month.</span>
      </h1>

      <!-- Subheading -->
      <p class="text-lg lg:text-xl mb-10 max-w-2xl leading-relaxed animate-fade-up animate-fade-up-delay-2" style="color:rgba(255,255,255,0.82);">
        One person. 40 hours a week. Your store, your processes, your timezone. Customer support, orders, catalogue, returns — every platform, fully managed.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 mb-12 animate-fade-up animate-fade-up-delay-3">
        <a href="/contact" class="inline-flex items-center justify-center bg-white text-dark font-bold px-8 py-4 rounded-xl text-lg hover:bg-gray-50 transition-colors shadow-lg shadow-black/20">
          Get started →
        </a>
        <a href="/how-it-works" class="inline-flex items-center justify-center border border-white/30 text-white font-semibold px-8 py-4 rounded-xl text-lg hover:border-white/60 hover:bg-white/8 transition-all">
          See how it works
        </a>
      </div>

      <!-- Trust line -->
      <p class="text-sm animate-fade-up animate-fade-up-delay-4" style="color:rgba(255,255,255,0.5);">
        No long-term contracts &nbsp;·&nbsp; Monthly billing &nbsp;·&nbsp; Named UK account manager
      </p>

    </div>
  </div>
</section>
