---
interface AccordionItem {
  question: string;
  answer: string;
}

interface Props {
  items: AccordionItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---
<div class={`divide-y divide-gray-200 ${className}`}>
  {items.map((item, index) => (
    <div class="accordion-item py-5">
      <button
        class="accordion-trigger w-full flex items-center justify-between gap-4 text-left font-semibold text-dark hover:text-purple transition-colors duration-150"
        aria-expanded="false"
        aria-controls={`accordion-content-${index}`}
        id={`accordion-trigger-${index}`}
        style="font-family: var(--font-heading); font-size: 1.1rem;"
      >
        <span>{item.question}</span>
        <span class="accordion-icon flex-shrink-0 w-6 h-6 flex items-center justify-center rounded-full border border-gray-300 transition-transform duration-300">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
        </span>
      </button>
      <div
        class="accordion-content"
        id={`accordion-content-${index}`}
        role="region"
        aria-labelledby={`accordion-trigger-${index}`}
      >
        <p class="pt-4 text-gray-600 leading-relaxed">{item.answer}</p>
      </div>
    </div>
  ))}
</div>

<script>
  document.querySelectorAll('.accordion-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling as HTMLElement;
      const icon = trigger.querySelector('.accordion-icon') as HTMLElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.accordion-trigger').forEach(t => {
        if (t !== trigger) {
          t.setAttribute('aria-expanded', 'false');
          const c = t.nextElementSibling as HTMLElement;
          const i = t.querySelector('.accordion-icon') as HTMLElement;
          if (c) c.classList.remove('open');
          if (i) i.style.transform = 'rotate(0deg)';
        }
      });

      // Toggle this one
      trigger.setAttribute('aria-expanded', String(!isOpen));
      if (content) content.classList.toggle('open', !isOpen);
      if (icon) icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(45deg)';
    });
  });
</script>
