---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  type?: 'button' | 'submit' | 'reset';
  target?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  type = 'button',
  target,
  ...rest
} = Astro.props;

const sizeClasses = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variantClasses = {
  primary: 'bg-electric-lime text-dark font-bold hover:opacity-90',
  secondary: 'border-2 border-current text-current font-semibold hover:bg-white/10',
  ghost: 'text-current font-semibold hover:underline',
};

const baseClasses = 'inline-flex items-center gap-2 rounded-lg transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-electric-lime focus:ring-offset-2';
const classes = `${baseClasses} ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;
---
{href ? (
  <a href={href} class={classes} target={target} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
  </button>
)}
