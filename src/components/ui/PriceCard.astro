---
interface Props {
  showAnnual?: boolean;
  highlighted?: boolean;
  class?: string;
}

const { showAnnual = false, highlighted = false, class: className = '' } = Astro.props;
---
<div class={`bg-white rounded-2xl border ${highlighted ? 'border-purple/30 shadow-xl shadow-purple/10 relative overflow-hidden' : 'border-gray-200'} p-8 ${className}`}>
  {highlighted && <div class="absolute top-0 left-0 right-0 h-1 bg-purple rounded-t-2xl"></div>}
  <div class={highlighted ? 'mt-2' : ''}>
    <p class="text-xs font-bold uppercase tracking-[0.12em] text-gray-400 mb-2">Standard Plan</p>
    <div class="flex items-baseline gap-2 mb-1">
      <span class="text-5xl font-extrabold text-coral" style="font-family: var(--font-heading);">£999</span>
      <span class="text-gray-400">/month</span>
    </div>
    <p class="text-sm text-gray-500">per dedicated operator</p>
  </div>

  <div class="my-6 p-4 bg-cream rounded-xl">
    <p class="text-sm text-gray-600 mb-1">Annual plan</p>
    <div class="flex items-center justify-between">
      <span class="font-bold text-dark">£9,990/year</span>
      <span class="text-xs bg-purple/10 text-purple px-2.5 py-1 rounded-full font-bold">Save £1,998</span>
    </div>
    <p class="text-xs text-gray-500 mt-1">Two months free</p>
  </div>

  <ul class="space-y-3 mb-8">
    {[
      '1 dedicated operator',
      '40 hours per week',
      'Matched to your timezone',
      'All platforms supported',
      'AI-trained, modern tooling',
      'Weekly reports & audit trail',
      'SOP documentation',
      'Free AI chatbot for your store',
      'Named account contact',
      'Cancel anytime'
    ].map(item => (
      <li class="flex items-start gap-3 text-sm">
        <svg class="w-5 h-5 text-purple flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
        <span class="text-gray-700">{item}</span>
      </li>
    ))}
  </ul>

  <a href="/contact" class="block w-full text-center bg-purple text-white font-bold py-4 rounded-xl hover:bg-[#6d28d9] transition-colors text-lg">
    Get started &rarr;
  </a>

  <p class="text-center text-xs text-gray-400 mt-4">No lock-in &middot; Cancel anytime &middot; GBP billing</p>
</div>
