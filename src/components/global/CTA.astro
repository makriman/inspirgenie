---
interface Props {
  heading?: string;
  subheading?: string;
  buttonText?: string;
  buttonHref?: string;
  email?: string;
}

const {
  heading = "Ready to stop doing everything yourself?",
  subheading = "One operator. 40 hours a week. Live in two weeks.",
  buttonText = "Get started →",
  buttonHref = "/contact",
  email = "hello@inspir.uk"
} = Astro.props;
---
<section class="relative py-20 lg:py-32 overflow-hidden" style="background: #1e40af;">
  <!-- Background accents -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 right-0 w-96 h-96 opacity-[0.12]" style="background: radial-gradient(circle, #7c3aed, transparent 70%); transform: translate(30%, -30%);"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 opacity-[0.08]" style="background: radial-gradient(circle, #B6F03C, transparent 70%); transform: translate(-20%, 30%);"></div>
  </div>

  <div class="container relative z-10 text-center">
    <p class="text-[#B6F03C] text-xs font-bold uppercase tracking-[0.14em] mb-4">Get started today</p>
    <h2 class="text-3xl lg:text-5xl font-extrabold text-white mb-5 max-w-2xl mx-auto leading-tight" style="font-family: var(--font-heading); letter-spacing: -0.02em;">
      {heading}
    </h2>
    <p class="text-blue-200 text-lg mb-10 max-w-xl mx-auto">{subheading}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={buttonHref} class="bg-white text-dark font-bold px-10 py-4 rounded-xl text-lg hover:bg-gray-50 transition-colors shadow-lg shadow-black/20">
        {buttonText}
      </a>
      <a href={`mailto:${email}`} class="text-blue-300 hover:text-white transition-colors text-sm">
        or email us: {email}
      </a>
    </div>
  </div>
</section>
