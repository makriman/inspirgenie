---
interface Props {
  heading?: string;
  subheading?: string;
  buttonText?: string;
  buttonHref?: string;
  email?: string;
}

const {
  heading = "Ready to stop doing everything yourself?",
  subheading = "One operator. 40 hours a week. Live in two weeks.",
  buttonText = "Get started →",
  buttonHref = "/contact",
  email = "hello@inspir.uk"
} = Astro.props;
---
<section class="relative py-20 lg:py-32 overflow-hidden" style="background-color: #0C1F40;">
  <!-- Dot-grid texture -->
  <div class="absolute inset-0 pointer-events-none" style="background-image: radial-gradient(circle, rgba(255,255,255,0.045) 1px, transparent 1px); background-size: 30px 30px;"></div>
  <!-- Amber glow -->
  <div class="absolute -bottom-32 left-1/2 -translate-x-1/2 w-[600px] h-[400px] pointer-events-none" style="background: radial-gradient(ellipse, rgba(233,168,40,0.10), transparent 70%);"></div>
  <div class="container relative z-10 text-center">
    <h2 class="text-3xl lg:text-5xl font-extrabold text-white mb-4 max-w-2xl mx-auto" style="font-family: var(--font-heading);">
      {heading}
    </h2>
    <p class="text-lg mb-10 max-w-xl mx-auto" style="color: rgba(255,255,255,0.60);">{subheading}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={buttonHref} class="bg-electric-lime text-dark font-bold px-10 py-4 rounded-xl text-lg hover:opacity-90 transition-opacity">
        {buttonText}
      </a>
      <a href={`mailto:${email}`} class="text-sm transition-colors hover:text-white" style="color: rgba(255,255,255,0.45);">
        or email us: {email}
      </a>
    </div>
  </div>
</section>
