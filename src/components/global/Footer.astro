---
import { footerNav } from '../../data/navigation';
const year = new Date().getFullYear();
---
<footer class="bg-dark" role="contentinfo">
  <div class="container py-16 lg:py-20">

    <!-- Top grid: brand col + 4 nav cols -->
    <div class="grid grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr_1fr] gap-10 pb-12" style="border-bottom: 1px solid rgba(255,255,255,0.08);">

      <!-- Brand -->
      <div class="col-span-2 lg:col-span-1">
        <a href="/" class="inline-block mb-5" aria-label="inspir - home">
          <span class="font-extrabold text-2xl text-white" style="font-family: var(--font-heading); letter-spacing: -0.04em;">inspir</span>
        </a>
        <p class="text-sm leading-relaxed mb-4" style="color: rgba(255,255,255,0.45);">
          Ecommerce operations,<br />fully managed.
        </p>
        <p class="text-xs" style="color: rgba(255,255,255,0.25);">
          One operator · 40 hrs/week · £999/mo
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-5">Services</h3>
        <ul class="space-y-3">
          {footerNav.services.map(item => (
            <li>
              <a href={item.href} class="text-sm transition-colors duration-150 hover:text-electric-lime" style="color: rgba(255,255,255,0.45);">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Platforms -->
      <div>
        <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-5">Platforms</h3>
        <ul class="space-y-3">
          {footerNav.platforms.map(item => (
            <li>
              <a href={item.href} class="text-sm transition-colors duration-150 hover:text-electric-lime" style="color: rgba(255,255,255,0.45);">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-5">Company</h3>
        <ul class="space-y-3">
          {footerNav.company.map(item => (
            <li>
              <a href={item.href} class="text-sm transition-colors duration-150 hover:text-electric-lime" style="color: rgba(255,255,255,0.45);">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal + Contact -->
      <div>
        <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-5">Legal</h3>
        <ul class="space-y-3 mb-8">
          {footerNav.legal.map(item => (
            <li>
              <a href={item.href} class="text-sm transition-colors duration-150 hover:text-electric-lime" style="color: rgba(255,255,255,0.45);">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
        <h3 class="text-white font-bold text-xs uppercase tracking-widest mb-4">Contact</h3>
        <a href="mailto:hello@inspir.uk" class="block text-sm transition-colors duration-150 hover:text-electric-lime mb-2" style="color: rgba(255,255,255,0.45);">hello@inspir.uk</a>
        <a href="tel:+447447793716" class="block text-sm transition-colors duration-150 hover:text-electric-lime" style="color: rgba(255,255,255,0.45);">+44 7447 793716</a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <div>
        <p class="footer-brand-line">inspir — Ecommerce Operations · Operated by inspir learning LTD</p>
        <p class="footer-company-line">Registered in England and Wales · London SW9 0PP</p>
      </div>
      <p class="footer-copyright">© 2024–{year} inspir learning LTD. All rights reserved.</p>
    </div>
  </div>
</footer>
