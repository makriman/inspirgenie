---
import { footerNav } from '../../data/navigation';
---
<footer class="bg-[#0a0614]" role="contentinfo">

  <!-- Main footer content -->
  <div class="container">
    <div class="pt-16 pb-14 lg:pt-20 lg:pb-16 flex flex-col lg:flex-row gap-12 lg:gap-8 border-b border-white/[0.07]">

      <!-- Brand column -->
      <div class="lg:w-64 xl:w-72 flex-shrink-0">
        <a href="/" class="inline-block mb-5" aria-label="inspir - home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 108 32" fill="white" class="h-8 w-auto" aria-hidden="true">
            <text x="0" y="25" font-family="'Plus Jakarta Sans', system-ui, sans-serif" font-weight="800" font-size="28" letter-spacing="-0.5">inspir</text>
          </svg>
        </a>
        <p class="text-[#9ca3af] text-sm leading-relaxed mb-1">
          Ecommerce operations,<br />fully managed.
        </p>
        <p class="text-[#6b7280] text-xs mt-3 leading-relaxed">
          One dedicated operator.<br />40 hours a week. £999/month.
        </p>

        <!-- Contact -->
        <div class="mt-6 space-y-1.5">
          <a href="mailto:hello@inspir.uk" class="flex items-center gap-2 text-[#9ca3af] text-sm hover:text-white transition-colors duration-150 group">
            <svg class="w-3.5 h-3.5 text-[#6b7280] group-hover:text-purple transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 4a1 1 0 00-1 1v1.586l8 5.33 8-5.33V5a1 1 0 00-1-1H3zM2 8.868V15a1 1 0 001 1h14a1 1 0 001-1V8.868l-8 5.331-8-5.331z"/>
            </svg>
            hello@inspir.uk
          </a>
          <a href="tel:+447447793716" class="flex items-center gap-2 text-[#9ca3af] text-sm hover:text-white transition-colors duration-150 group">
            <svg class="w-3.5 h-3.5 text-[#6b7280] group-hover:text-purple transition-colors flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            +44 7447 793716
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 flex-1">

        <!-- Services -->
        <div>
          <h3 class="text-white font-bold text-xs uppercase tracking-[0.12em] mb-4">Services</h3>
          <ul class="space-y-2.5">
            {footerNav.services.map(item => (
              <li>
                <a href={item.href} class="text-[#9ca3af] text-sm hover:text-white transition-colors duration-150">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Platforms -->
        <div>
          <h3 class="text-white font-bold text-xs uppercase tracking-[0.12em] mb-4">Platforms</h3>
          <ul class="space-y-2.5">
            {footerNav.platforms.map(item => (
              <li>
                <a href={item.href} class="text-[#9ca3af] text-sm hover:text-white transition-colors duration-150">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Company -->
        <div>
          <h3 class="text-white font-bold text-xs uppercase tracking-[0.12em] mb-4">Company</h3>
          <ul class="space-y-2.5">
            {footerNav.company.map(item => (
              <li>
                <a href={item.href} class="text-[#9ca3af] text-sm hover:text-white transition-colors duration-150">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h3 class="text-white font-bold text-xs uppercase tracking-[0.12em] mb-4">Legal</h3>
          <ul class="space-y-2.5">
            {footerNav.legal.map(item => (
              <li>
                <a href={item.href} class="text-[#9ca3af] text-sm hover:text-white transition-colors duration-150">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-7 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
      <div>
        <p class="text-[#4b5563] text-xs">
          inspir learning LTD &nbsp;·&nbsp; Registered in England and Wales &nbsp;·&nbsp; London SW9 0PP
        </p>
      </div>
      <p class="text-[#4b5563] text-xs flex-shrink-0">
        © 2024–2026 inspir learning LTD. All rights reserved.
      </p>
    </div>
  </div>

</footer>
