---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noindex?: boolean;
}

const props = Astro.props;
---
<BaseLayout {...props}>
  <slot name="head" slot="head" />
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
